<IfModule mod_rewrite.c>
  RewriteEngine On
  
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
  
  RewriteCond %{REQUEST_URI} !^/public/
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# BEGIN cPanel-generated php ini directives, do not edit
# Estas configuraciones son generadas automáticamente por cPanel.
# Si necesitas hacer cambios, utiliza el MultiPHP INI Editor.
<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 300        # Limitar a 5 minutos
   php_value max_input_time 300            # Limitar a 5 minutos
   php_value max_input_vars 5000           # Valor razonable para formularios grandes
   php_value memory_limit 512M             # Límite de memoria ajustado
   php_value post_max_size 50M             # Tamaño máximo de POST a 50MB
   php_value session.gc_maxlifetime 1440   # Tiempo de vida de sesiones (24 minutos)
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 50M       # Tamaño máximo de subida de archivos a 50MB
   php_flag zlib.output_compression On
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 300
   php_value max_input_time 300
   php_value max_input_vars 5000
   php_value memory_limit 512M
   php_value post_max_size 50M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 50M
   php_flag zlib.output_compression On
</IfModule>
# END cPanel-generated php ini directives, do not edit

